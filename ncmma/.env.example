# Discord Webhook URL
DISCORD_WEBHOOK_URL=""

# CMMA API ベースURL
CMMA_API_BASE_URL="https://stg.api.1btc.love"

# --- Funding Rate 監視設定 ---
# 異常と判断する金利の閾値 (例: 0.1% = 0.001)
FUNDING_RATE_THRESHOLD="0.001"
# 監視する方向 ('positive': プラス金利, 'negative': マイナス金利, 'both': 両方)
FUNDING_RATE_DIRECTION="both"
# ソート順 ('funding_abs_desc': 絶対値降順, 'funding_rate_desc': 降順, 'funding_rate_asc': 昇順)
FUNDING_RATE_SORT="funding_abs_desc"
# 一度に取得する候補の最大数
FUNDING_RATE_LIMIT="100"

# --- 継続性分析設定 ---
# 過去何回分のFunding Rateを分析対象とするか (例: 24)
FUNDING_RATE_LOOKBACK="24"

# --- 通知・ログ設定 ---
# 1回のチェックで通知する最大件数
MAX_NOTIFICATIONS="20"
# 同一シンボル・方向に対して再通知を行うまでの待機時間（分）
RENOTIFY_BUFFER_MINUTES="240"
# チェックサイクル間の間隔（秒）
CHECK_INTERVAL_SECONDS="300"
# ログディレクトリの最大サイズ（MB）
LOG_MAX_SIZE_MB="10"